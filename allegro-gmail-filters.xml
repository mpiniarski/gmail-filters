<?xml version='1.0' encoding='UTF-8'?>
<feed xmlns='http://www.w3.org/2005/Atom' xmlns:apps='http://schemas.google.com/apps/2006'>
  <title>Mail Filters</title>

  <!-- Filter 1: Label ALL emails from Allegro -->
  <entry>
    <category term='filter'></category>
    <title>Mail Filter</title>
    <apps:property name='from' value='@allegro.pl OR @allegromail.pl'/>
    <apps:property name='label' value='Allegro'/>
    <apps:property name='sizeOperator' value='s_sl'/>
    <apps:property name='sizeUnit' value='s_smb'/>
  </entry>

  <!-- Filter 2: Archive + mark read everything except actionable emails.
       Kept: delivery ready, pickup reminders, returns, refunds, payment alerts, cancellations. -->
  <entry>
    <category term='filter'></category>
    <title>Mail Filter</title>
    <apps:property name='from' value='@allegro.pl OR @allegromail.pl'/>
    <apps:property name='doesNotHaveTheWord' value='&quot;czeka na odbiór&quot; &quot;gotowa do odbioru&quot; &quot;czeka na Ciebie&quot; &quot;czekają na Ciebie&quot; &quot;przypomnienie o odbiorze&quot; zwrot opłacenie &quot;nie udała&quot; anulowany'/>
    <apps:property name='label' value='Allegro'/>
    <apps:property name='shouldAlwaysMarkAsRead' value='true'/>
    <apps:property name='shouldArchive' value='true'/>
    <apps:property name='sizeOperator' value='s_sl'/>
    <apps:property name='sizeUnit' value='s_smb'/>
  </entry>

</feed>
